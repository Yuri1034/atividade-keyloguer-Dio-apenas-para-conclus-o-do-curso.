import os
from cryptography.fernet import Fernet

# Gerar chave
chave = Fernet.generate_key()

# Salvar chave
with open("chave.key", "wb") as key_file:
    key_file.write(chave)

fernet = Fernet(chave)

pasta = "arquivos_teste"

for arquivo in os.listdir(pasta):
    caminho = os.path.join(pasta, arquivo)

    with open(caminho, "rb") as f:
        dados = f.read()

    dados_criptografados = fernet.encrypt(dados)

    with open(caminho, "wb") as f:
        f.write(dados_criptografados)
print("Arquivos criptografados!")
from cryptography.fernet import Fernet

# Carregar chave
with open("chave.key", "rb") as key_file:
    chave = key_file.read()

fernet = Fernet(chave)

pasta = "arquivos_teste"

for arquivo in os.listdir(pasta):
    caminho = os.path.join(pasta, arquivo)

    with open(caminho, "rb") as f:
        dados = f.read()

    dados_descriptografados = fernet.decrypt(dados)

    with open(caminho, "wb") as f:
        f.write(dados_descriptografados)

print("Arquivos restaurados!")
